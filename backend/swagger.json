        }
      }
    },
    "/api/events": {
      "get": {
        "summary": "Get all events",
        "description": "Retrieve list of events with filtering by city_id, category_id, status, and search query.",
        "parameters": [
          { "name": "city_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "category_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active", "cancelled", "completed"] } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful retrieval of events" }
        }
      },
      "post": {
        "summary": "Create a new event",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "category_id": { "type": "string", "format": "uuid" },
                  "city_id": { "type": "string", "format": "uuid" },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "venue": { "type": "string" },
                  "banner": { "type": "string", "format": "url" },
                  "start_date": { "type": "string", "format": "date-time" },
                  "end_date": { "type": "string", "format": "date-time" },
                  "tickets": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "ticket_type": { "type": "string" },
                        "price": { "type": "number" },
                        "available_quantity": { "type": "integer" }
                      },
                      "required": ["ticket_type", "price", "available_quantity"]
                    }
