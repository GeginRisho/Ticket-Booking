        "parameters": [
          { "name": "city_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active", "inactive", "pending_approval"] } },
          { "name": "owner_id", "in": "query", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Successful retrieval of theatres" }
        }
      },
      "post": {
        "summary": "Create a new theatre",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "city_id": { "type": "string", "format": "uuid" },
                  "theatre_name": { "type": "string" },
                  "address": { "type": "string" },
                  "latitude": { "type": "number" },
                  "longitude": { "type": "number" },
                  "phone": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "description": { "type": "string" }
                },
                "required": ["city_id", "theatre_name", "address"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Theatre created successfully" }
        }
      }
    },
    "/api/theatres/{id}": {
