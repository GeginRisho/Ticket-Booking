    "/api/events/categories": {
      "get": {
        "summary": "Get all event categories",
        "responses": {
          "200": { "description": "Successful retrieval of categories" }
        }
      },
      "post": {
        "summary": "Create a new event category (Admin only)",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "category_name": { "type": "string" }
                },
