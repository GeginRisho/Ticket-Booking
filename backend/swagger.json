        "summary": "Get all shows",
        "description": "Retrieve scheduled shows with filtering by movie_id, screen_id, date, and city_id.",
        "parameters": [
          { "name": "movie_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "screen_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "city_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "date", "in": "query", "schema": { "type": "string", "format": "date" } }
