                },
                "required": ["status"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Theatre status updated successfully" }
        }
      }
    },
    "/api/theatres/{theatreId}/screens": {
      "get": {
        "summary": "Get screens for a theatre",
