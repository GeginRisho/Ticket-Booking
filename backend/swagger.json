            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "city_id": { "type": "string", "format": "uuid" },
                  "theatre_name": { "type": "string" },
                  "address": { "type": "string" },
                  "latitude": { "type": "number" },
                  "longitude": { "type": "number" },
                  "phone": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Theatre updated successfully" }
        }
